{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "The",
  "scopeName": "source.the",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    {
      "match": "^(PAGE)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(\\d+)\\s+(OF)\\s+(\\d+))?",
      "captures": {
        "1": { "name": "constant.numeric.page.the" },
        "2": { "name": "entity.name.section.page.the" },
        "3": { "name": "constant.numeric.schedule.the" },
        "4": { "name": "keyword.operator.schedule.the" },
        "5": { "name": "constant.numeric.schedule.the" }
      }
    },
    {
      "match": "^(PAGEEND)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "constant.numeric.page.the" },
        "2": { "name": "entity.name.section.page.the" }
      }
    },
    {
      "match": "\\b(PROC)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.procedure.the" },
        "2": { "name": "entity.name.function.the" }
      }
    },
    { "match": "\\bPROCEND\\b", "name": "keyword.declaration.procedure.the" },
    {
      "match": "\\b(ENTRY)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.entry.the" },
        "2": { "name": "entity.name.function.entry.the" }
      }
    },
    { "match": "\\b(ITEREND|LOOPEND|IFEND|MATCHEND)\\b", "name": "keyword.control.end.the" },
    { "match": "\\b(ITER|LOOP|RUN|PUT|OBJ|RETURN|IF|ELSE|MATCH|STOP|NEXT|USE|RAW|OUT)\\b", "name": "keyword.control.the" },
    { "match": "\\b(intthrough|stridethrough)\\b", "name": "keyword.declaration.procedure.the" },
    { "match": "\\binto\\b", "name": "constant.numeric.connector.the" },
    { "match": "\\bat\\b", "name": "entity.name.section.position.the" },
    { "match": "\\b(end|beginning|value)\\b", "name": "markup.inserted.position.the" },
    { "match": "\\b(through|as|in)\\b", "name": "keyword.control.the" },
    { "match": "\\b(OPEN)(?=\\.)", "name": "variable.language.scope.the" },
    { "match": "\\.\\.", "name": "punctuation.separator.continuation.the" },
    { "match": "\\b(BOOL|BYTE|CHAR|INT|UINT|FLOAT|STRING|LIST|RESULT|OPTION|VOID)\\b", "name": "storage.type.the" },
    { "match": "\\b(TRUE|FALSE|NONE)\\b", "name": "constant.language.the" },
    { "match": "\\b(?:0[xX][0-9A-Fa-f]+|0[bB][01]+|[0-9]+(?:\\.[0-9]+)?)\\b", "name": "constant.numeric.the" },
    { "match": "(?:==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|=|<|>|%|\\+|-|\\*|/)", "name": "keyword.operator.the" },
    { "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()", "name": "entity.name.function.call.the" },
    { "match": "\\.[A-Za-z_][A-Za-z0-9_]*", "name": "variable.other.property.the" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "\\|\\|.*?\\|\\|", "name": "comment.block.the" },
        {
          "begin": "^\\s*\\|\\|\\s*$",
          "end": "^\\s*\\|\\|\\s*$",
          "name": "comment.block.the"
        },
        {
          "begin": "\\|(?=[^\\r\\n]*\\.\\.\\s*$)",
          "end": "(?<!\\.\\.)\\r?\\n",
          "applyEndPatternLast": true,
          "name": "comment.line.continued.the"
        },
        { "begin": "\\|", "end": "$", "name": "comment.line.the" }
      ]
    },
    "strings": {
      "patterns": [
        { "begin": "\"", "end": "\"", "name": "string.quoted.double.the", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.the" }] },
        { "begin": "'", "end": "'", "name": "string.quoted.single.the", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.the" }] }
      ]
    }
  }
}
