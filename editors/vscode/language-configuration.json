{
  "comments": {
    "lineComment": "|",
    "blockComment": ["||", "||"]
  },
  "brackets": [["[", "]"], ["(", ")"], ["{", "}"]],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [["[", "]"], ["(", ")"], ["{", "}"], ["\"", "\""], ["'", "'"]],
  "folding": {
    "markers": {
      "start": "^\\s*(?:PAGE |PROC |ITER |IF\\b|LOOP\\b)",
      "end": "^\\s*(?:PAGEEND|PROCEND|ITEREND|IFEND|LOOPEND)\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:PAGE |PROC |ITER |IF\\b|LOOP\\b).*$",
    "decreaseIndentPattern": "^\\s*(?:PAGEEND|PROCEND|ITEREND|IFEND|LOOPEND)\\b"
  }
}
