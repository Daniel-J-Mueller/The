{
  "$schema": "vscode://schemas/color-theme",
  "name": "The",
  "type": "dark",
  "colors": {
    "editor.background": "#351332",
    "editor.foreground": "#EACBA3",
    "editorCursor.foreground": "#CC2038",
    "editorLineNumber.foreground": "#699A96",
    "editorLineNumber.activeForeground": "#EACBA3",
    "editor.selectionBackground": "#454758CC",
    "editor.inactiveSelectionBackground": "#45475888",
    "editor.lineHighlightBackground": "#45475855",
    "editorIndentGuide.background1": "#454758",
    "editorIndentGuide.activeBackground1": "#699A96",
    "editorWhitespace.foreground": "#454758",
    "editorBracketMatch.background": "#699A9644",
    "editorBracketMatch.border": "#EACBA3",
    "editorGutter.background": "#351332",
    "editorError.foreground": "#CC2038",
    "editorWarning.foreground": "#D99A73",
    "editorInfo.foreground": "#699A96",
    "activityBar.background": "#2A0F28",
    "activityBar.foreground": "#EACBA3",
    "sideBar.background": "#30122E",
    "sideBar.foreground": "#D8C6D5",
    "statusBar.background": "#454758",
    "statusBar.foreground": "#F2DFC5",
    "titleBar.activeBackground": "#2A0F28",
    "titleBar.activeForeground": "#EACBA3",
    "panel.background": "#30122E",
    "terminal.background": "#351332",
    "terminal.foreground": "#EACBA3"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#699A96", "fontStyle": "italic" } },
    { "scope": ["keyword", "storage", "keyword.control.the"], "settings": { "foreground": "#CC2038" } },
    { "scope": ["keyword.declaration.procedure.the"], "settings": { "foreground": "#E05D70", "fontStyle": "bold" } },
    { "scope": ["constant.numeric.page.the"], "settings": { "foreground": "#C8A7C3", "fontStyle": "bold" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#EACBA3" } },
    { "scope": ["constant.numeric.connector.the"], "settings": { "foreground": "#F2D9B8", "fontStyle": "bold" } },
    { "scope": ["entity.name.section.position.the"], "settings": { "foreground": "#D99A73" } },
    { "scope": ["markup.inserted.position.the"], "settings": { "foreground": "#8FBDA8" } },
    { "scope": ["string", "constant.character.escape"], "settings": { "foreground": "#9FC8C4" } },
    { "scope": ["entity.name.function", "entity.name.section"], "settings": { "foreground": "#E8B5BC" } },
    { "scope": ["storage.type", "support.type"], "settings": { "foreground": "#A8CFCA" } },
    { "scope": ["variable.language", "variable.other.property"], "settings": { "foreground": "#B9BAC7" } },
    { "scope": ["keyword.operator", "punctuation.separator.continuation.the"], "settings": { "foreground": "#D4A6CF" } },
    { "scope": ["variable", "identifier"], "settings": { "foreground": "#E6D8E3" } }
  ]
}
